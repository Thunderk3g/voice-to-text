# =========================================================================
# v2t Insurance Call Intelligence — SARVAM profile
# High-accuracy Hindi/Indic STT via Sarvam.ai (needs SARVAM_API_KEY), with a
# native Ollama LLM on the Mac host (Metal-accelerated, reached via
# host.docker.internal) and local multilingual-e5-large embeddings on CPU.
#
# Usage:  cp .env.sarvam .env  &&  set SARVAM_API_KEY  &&  docker compose up -d --build
# (Sister profile: .env.opensource — fully open-source, faster-whisper STT.)
# =========================================================================

# -------------------------- App / runtime --------------------------
APP_ENV=local                            # local | dev | staging | prod
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8080

# -------------------------- Postgres + pgvector --------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=v2t
POSTGRES_USER=v2t
POSTGRES_PASSWORD=v2t_pw
DATABASE_URL=postgresql+asyncpg://v2t:v2t_pw@postgres:5432/v2t
DATABASE_URL_SYNC=postgresql+psycopg://v2t:v2t_pw@postgres:5432/v2t

# -------------------------- Redis (Celery broker + result) --------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -------------------------- MinIO / object storage --------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_admin_pw
MINIO_SECURE=false
MINIO_BUCKET_AUDIO=audio-raw
MINIO_BUCKET_TRANSCRIPTS=transcripts
MINIO_BUCKET_ARTIFACTS=pipeline-artifacts

# -------------------------- Sarvam.ai STT --------------------------
# Provider switch: "sarvam" runs the on-board STT pipeline; "whisper" runs
# open-source faster-whisper (see .env.opensource); "none" disables audio
# ingest entirely (all calls must arrive as pre-labeled transcripts).
STT_PROVIDER=sarvam
SARVAM_API_KEY=
SARVAM_STT_MODEL=saarika:v2.5            # transcription model (saaras:v3 = translation)
SARVAM_LANGUAGE_CODE=unknown             # "unknown" auto-detects; or "hi-IN", "en-IN", "ta-IN", "te-IN" etc.
SARVAM_REQUEST_TIMEOUT_S=60
SARVAM_CHUNK_DURATION_S=25               # < 30s sync limit, leave headroom
SARVAM_CHUNK_OVERLAP_MS=200              # bleed between chunks to avoid clipping words

# -------------------------- LLM (OpenAI-compatible HTTP) --------------------------
# LLM — native Ollama on the Mac host (Metal-accelerated)
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b-instruct
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1
LLM_REQUEST_TIMEOUT_S=180

# ---- Groq (commented out — uncomment to use a hosted LLM instead of Ollama) ----
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=<your-groq-key>
# LLM_MODEL=openai/gpt-oss-120b

# -------------------------- Embeddings --------------------------
# Embeddings — local multilingual-e5-large on CPU
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_SEQ_LEN=512

# -------------------------- Cohere embeddings (present but unused; EMBEDDING_PROVIDER=local) --------------------------
COHERE_API_KEY=
COHERE_BASE_URL=https://api.cohere.com/v2
COHERE_EMBED_MODEL=embed-multilingual-v3.0
COHERE_BATCH_SIZE=90                     # Cohere caps at 96 per call
COHERE_REQUEST_TIMEOUT_S=60

# -------------------------- Clustering --------------------------
HDBSCAN_MIN_CLUSTER_SIZE=8
HDBSCAN_MIN_SAMPLES=4
HDBSCAN_METRIC=euclidean
CLUSTER_INCREMENTAL_THRESHOLD=0.78
CLUSTER_REASSIGN_PERIOD=24h

# -------------------------- Memory graph --------------------------
MEMORY_EDGE_TOP_K=8
MEMORY_EDGE_MIN_SIM=0.55
MEMORY_EDGE_MAX_PER_CLUSTER=6

# -------------------------- Observability --------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=v2t-api
PROMETHEUS_PORT=9100

# -------------------------- Frontend --------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
