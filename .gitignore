# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
*.cover
*.log

# Virtualenvs
.venv/
venv/
env/

# Local config / secrets
.env
.env.local
.env.*.local
*.pem
*.key

# Corporate CA bundles (per-developer; injected into images at build time)
infra/certs/*.crt
frontend/certs/*.crt

# Node / Next.js
node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/build/
frontend/.vercel/

# Editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Docker
*.pid
docker_ps.txt

# Data / artefacts (keep sample transcripts; ignore everything else under data/)
data/sample_audio/*
!data/sample_audio/.gitkeep
data/sample_transcripts/.seeded.json

# Raw dataset audio — bulk local-only corpus (thousands of mp3s, multi-GB).
# Too large for the repo; kept out of git. The 17 already-tracked preprocessed
# calls stay tracked (gitignore does not untrack existing files).
dataset/*.mp3

# Local model caches
.cache/
hf_cache/
torch_home/

# Build outputs
dist/
build/
*.egg
