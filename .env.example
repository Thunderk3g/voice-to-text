# =========================================================================
# v2t Insurance Call Intelligence â€” Environment Variables
# Copy to .env and fill in real values for local/dev/prod.
#
# This template is OPEN-SOURCE-FIRST: native Ollama LLM (reached via
# host.docker.internal), local multilingual-e5-large embeddings on CPU, and
# open-source faster-whisper STT â€” no paid API keys required out of the box.
#
# Prefer a ready-made profile? Two are provided:
#   cp .env.opensource .env   â€” fully open-source (faster-whisper STT, CPU)
#   cp .env.sarvam .env       â€” high-accuracy Hindi/Indic STT (needs SARVAM_API_KEY)
#
# STT provider (STT_PROVIDER): "whisper" runs open-source faster-whisper;
# "sarvam" runs the Sarvam.ai pipeline (Hindi-native + 10 Indic languages);
# "none" disables audio ingest (all calls arrive as pre-labeled transcripts).
# Already-transcribed inputs can be ingested via /ingest with is_transcript=true.
# =========================================================================

# -------------------------- App / runtime --------------------------
APP_ENV=local                            # local | dev | staging | prod
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8080

# -------------------------- Postgres + pgvector --------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=v2t
POSTGRES_USER=v2t
POSTGRES_PASSWORD=v2t_pw
DATABASE_URL=postgresql+asyncpg://v2t:v2t_pw@postgres:5432/v2t
DATABASE_URL_SYNC=postgresql+psycopg://v2t:v2t_pw@postgres:5432/v2t

# -------------------------- Redis (Celery broker + result) --------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -------------------------- MinIO / object storage --------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_admin_pw
MINIO_SECURE=false
MINIO_BUCKET_AUDIO=audio-raw
MINIO_BUCKET_TRANSCRIPTS=transcripts
MINIO_BUCKET_ARTIFACTS=pipeline-artifacts

# -------------------------- STT --------------------------
# Provider switch (STT_PROVIDER): "whisper" | "sarvam" | "none".
#   whisper â€” open-source faster-whisper (default here; runs on CPU)
#   sarvam  â€” Sarvam.ai on-board STT pipeline (Hindi-native + 10 Indic langs)
#   none    â€” disables audio ingest (all calls arrive as pre-labeled transcripts)
STT_PROVIDER=whisper

# ---- faster-whisper (open-source; STT_PROVIDER=whisper) ----
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu                       # cpu | cuda
WHISPER_COMPUTE_TYPE=int8               # int8 is fastest on CPU; float16 for cuda
WHISPER_LANGUAGE=                        # empty = auto-detect; or "hi", "en", "ta", "te"

# ---- Sarvam.ai (STT_PROVIDER=sarvam) ----
SARVAM_API_KEYS=                         # comma-separated key pool, one key per Sarvam account
SARVAM_STT_MODEL=saaras:v3               # current flagship; saarika:v2.5 slated for deprecation
SARVAM_LANGUAGE_CODE=unknown             # "unknown" auto-detects; or "hi-IN", "en-IN", "ta-IN", "te-IN" etc.
SARVAM_REQUEST_TIMEOUT_S=60
SARVAM_NUM_SPEAKERS=2                    # batch diarization hint (call centre = 2)
SARVAM_BATCH_POLL_INTERVAL_S=10          # batch rate limit counts status polls too
SARVAM_BATCH_TIMEOUT_S=1800

# -------------------------- LLM (OpenAI-compatible HTTP) --------------------------
# Single source of truth for ALL LLM calls. Works with Ollama, Groq, OpenAI,
# vLLM, or any OpenAI-compatible endpoint. To swap providers, change these
# vars and restart â€” no code changes needed.
#
# LLM â€” native Ollama on the Mac host (Metal-accelerated), reached from
# containers via host.docker.internal.
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=gemma4:latest
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1
LLM_REQUEST_TIMEOUT_S=180

# ---- Groq (commented out â€” uncomment to use a hosted LLM instead of Ollama) ----
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=<your-groq-key>
# LLM_MODEL=openai/gpt-oss-120b

# -------------------------- Embeddings --------------------------
# Provider: "local" (SentenceTransformer on CPU, default) or "cohere" (hosted).
# Both produce 1024-dim vectors so the pgvector schema is identical.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024
EMBEDDING_DEVICE=cpu                     # cuda | cpu  (used only when provider=local)
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_SEQ_LEN=512

# -------------------------- Cohere embeddings (provider=cohere) --------------------------
COHERE_API_KEY=
COHERE_BASE_URL=https://api.cohere.com/v2
COHERE_EMBED_MODEL=embed-multilingual-v3.0
COHERE_BATCH_SIZE=90                     # Cohere caps at 96 per call
COHERE_REQUEST_TIMEOUT_S=60

# -------------------------- Clustering --------------------------
HDBSCAN_MIN_CLUSTER_SIZE=8
HDBSCAN_MIN_SAMPLES=4
HDBSCAN_METRIC=euclidean
CLUSTER_INCREMENTAL_THRESHOLD=0.78
CLUSTER_REASSIGN_PERIOD=24h

# -------------------------- Memory graph --------------------------
MEMORY_EDGE_TOP_K=8
MEMORY_EDGE_MIN_SIM=0.55
MEMORY_EDGE_MAX_PER_CLUSTER=6

# -------------------------- Observability --------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=v2t-api
PROMETHEUS_PORT=9100

# -------------------------- Frontend --------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
