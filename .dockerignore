# =========================================================================
# Files excluded from Docker build context across all images.
# =========================================================================

# VCS
.git
.gitignore
.gitattributes
.github

# Python build artefacts
**/__pycache__
**/*.py[cod]
**/*$py.class
**/*.egg-info
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/.coverage
**/htmlcov
**/.tox
**/.nox
.venv
venv
env

# Node / Next.js
frontend/node_modules
frontend/.next
frontend/.turbo
frontend/out
frontend/coverage
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Editor / OS
.idea
.vscode
*.swp
*.swo
.DS_Store
Thumbs.db

# Local secrets
.env
.env.*
!.env.example

# Large local-only assets — keep transcripts (small JSON), drop heavy audio.
data/sample_audio/*.wav
data/sample_audio/*.mp3
data/sample_audio/*.flac
data/*.parquet
data/exports

# Docs / meta we don't need inside images
docs
*.md
!README.md

# Misc
logs
*.log
*.tmp
*.bak
dist
build
